rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile document security: Only the owner can read or write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Nested transactions subcollection: Only the owner can read or write
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
